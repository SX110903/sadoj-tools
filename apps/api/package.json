{
  "name": "@sadoj/api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "pnpm --filter @sadoj/shared build && tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma": "prisma"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cookie": "9.4.0",
    "@fastify/cors": "9.0.1",
    "@fastify/helmet": "11.1.1",
    "@fastify/multipart": "8.3.1",
    "@fastify/rate-limit": "9.1.0",
    "@prisma/client": "5.22.0",
    "@sadoj/shared": "workspace:*",
    "bcryptjs": "2.4.3",
    "dotenv": "16.4.7",
    "fastify": "4.29.1",
    "fastify-plugin": "4.5.1",
    "ioredis": "5.4.2",
    "jsonwebtoken": "9.0.2",
    "minio": "8.0.5",
    "sharp": "0.33.5",
    "socket.io": "4.8.1",
    "winston": "3.17.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "20.19.0",
    "prisma": "5.22.0",
    "tsx": "4.20.3",
    "typescript": "5.4.5"
  }
}

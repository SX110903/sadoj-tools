# ─────────────────────────────────────────────────────────────────────────────
# Variables de PRODUCCIÓN para `docker compose -f docker/docker-compose.yml`
#
# 1) Copia este fichero a `.env` en la raíz del proyecto EN EL SERVIDOR.
# 2) Rellena todos los valores (los marcados como REQUERIDO no pueden faltar).
# 3) NO subas el `.env` real al repositorio (ya está en .gitignore).
#
# Genera secretos fuertes con:
#   openssl rand -base64 48        (o en PowerShell: [Convert]::ToBase64String((1..48|%{Get-Random -Max 256})))
# ─────────────────────────────────────────────────────────────────────────────

# --- Base de datos (PostgreSQL) ---
# REQUERIDO. Contraseña del usuario 'sadoj'. Se usa en Postgres y en DATABASE_URL.
DB_PASSWORD=

# --- Redis ---
# REQUERIDO. Contraseña de Redis (sesiones / blacklist de tokens).
REDIS_PASSWORD=

# --- JWT (autenticación) ---
# REQUERIDO. Mínimo 32 caracteres. Deben ser DISTINTOS entre sí.
JWT_SECRET=
JWT_REFRESH_SECRET=

# --- Almacenamiento de ficheros (MinIO, compatible S3) ---
# REQUERIDO. Credenciales del almacenamiento de objetos.
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
# Opcional (por defecto: sadoj-files)
MINIO_BUCKET=sadoj-files

# --- CORS ---
# REQUERIDO. Origen(es) permitido(s) del frontend, separados por comas.
# Pon tu dominio real, por ejemplo: https://sadoj.tudominio.com
CORS_ORIGIN=https://tu-dominio.com

# --- Límites ---
# Opcional (por defecto: 10). Tamaño máximo de subida en MB.
MAX_FILE_SIZE_MB=10

# ─────────────────────────────────────────────────────────────────────────────
# NOTAS
# - El compose de producción levanta: postgres, redis, minio, api, web y nginx.
# - nginx espera `docker/nginx/nginx.conf` y certificados TLS en `docker/ssl/`
#   (crea esos ficheros en el servidor; para TLS puedes usar Let's Encrypt/Certbot).
# - La API aplica las migraciones automáticamente al arrancar
#   (`prisma migrate deploy` en el entrypoint). Tras el primer despliegue,
#   ejecuta el seed una vez si quieres el usuario admin y datos base:
#     docker compose -f docker/docker-compose.yml exec api pnpm exec prisma db seed
# ─────────────────────────────────────────────────────────────────────────────
